# Aria Voice AI - Environment Variables

# Google Gemini API Key (required)
GOOGLE_API_KEY=your_google_api_key

# Twilio Configuration (required for phone calls)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX

# Resend Email API (optional - for email notifications)
RESEND_API_KEY=your_resend_api_key

# Dashboard Webhook (optional - for call logging)
DASHBOARD_WEBHOOK_URL=https://your-dashboard.vercel.app
WEBHOOK_SECRET=aria-voice-2024

# Business Owner Defaults
OWNER_EMAIL=your@email.com
OWNER_PHONE=+1XXXXXXXXXX

# Render URL (for keep-alive ping)
RENDER_EXTERNAL_URL=https://your-app.onrender.com

# Server
PORT=5050
